# ─── Base Network ─────────────────────────────────────────────────────────────
# "testnet" (Base Sepolia) or "mainnet" (Base Mainnet)
NEXT_PUBLIC_BASE_NETWORK=testnet

# ─── Supabase (Phase 1) ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ─── Coinbase Developer Platform (Phase 2) ───────────────────────────────────
CDP_API_KEY=your-cdp-api-key
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your-onchainkit-key

# ─── Escrow Contract (Phase 3) ───────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...your-deployer-private-key
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_ESCROW_CONTRACT=0x...deployed-contract-address

# ─── AgentKit (Phase 4) ──────────────────────────────────────────────────────
AGENTKIT_WALLET_SECRET=your-agent-wallet-secret

# ─── Production (Phase 6) ────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
# SENTRY_DSN=https://your-sentry-dsn

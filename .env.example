# ─── Base Network (REQUIRED — no default) ─────────────────────────────────────
# "testnet" (Base Sepolia) or "mainnet" (Base Mainnet)
# CRITICAL: Must be set explicitly. No default — app will fail without it.
NEXT_PUBLIC_BASE_NETWORK=testnet

# ─── USDC Contract Address (REQUIRED — differs per network) ───────────────────
# Sepolia:  0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Mainnet:  0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ─── Supabase (Phase 1) ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Coinbase Developer Platform (Phase 2) ───────────────────────────────────
CDP_API_KEY=your-cdp-api-key
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your-onchainkit-key

# ─── Escrow Contract (Phase 3) ───────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0x...your-deployer-private-key
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# BASE_MAINNET_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_ESCROW_CONTRACT=0x...deployed-contract-address

# ─── x402 Protocol (Phase 4) ─────────────────────────────────────────────────
# Public URL of this server (used in fund_url returned by request_human_work)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Wallet that receives x402 payments (defaults to NEXT_PUBLIC_ESCROW_CONTRACT)
# PLATFORM_WALLET_ADDRESS=0x...your-platform-wallet

# ─── GCP Cloud KMS (Phase 7 — production signer via HSM) ─────────────────
# When set, the platform signer uses GCP Cloud KMS instead of DEPLOYER_PRIVATE_KEY.
# The private key never leaves Google's HSM. All values below are non-sensitive metadata.
# GCP_KMS_KEY_PATH=projects/carbon-contractors/locations/us-central1/keyRings/carbon-contractors/cryptoKeys/escrow-signer/cryptoKeyVersions/1
# GCP_PROJECT_NUMBER=529104096274
# GCP_WORKLOAD_IDENTITY_POOL_ID=carbon-contractors-pool
# GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=vercel
# GCP_SERVICE_ACCOUNT_EMAIL=kms-signer-svc@carbon-contractors.iam.gserviceaccount.com

# ─── Reputation Staking (Phase 5) ────────────────────────────────────────────
NEXT_PUBLIC_REPUTATION_STAKE_CONTRACT=0x...deployed-reputation-stake-address

# ─── Production (Phase 6) ────────────────────────────────────────────────────
# Session timeout in ms (default: 1800000 = 30 min)
# SESSION_TIMEOUT_MS=1800000
# Max concurrent MCP sessions (default: 100)
# MAX_SESSIONS=100
# Rate limiting: requests per window (default: 60 per 60s)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=60

# ─── Upstash Redis (optional — enables distributed rate limiting) ──────────
# Without these, rate limiting falls back to in-memory (single-instance only).
# Create a free database at console.upstash.com, copy REST URL and token.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here

# ─── Tip Jar / Buy Me a Coffee ─────────────────────────────────────────────
# Wallet address that receives USDC tips from the "Buy Me a Coffee" footer buttons.
NEXT_PUBLIC_TIP_WALLET_ADDRESS=0x...your-wallet-address

# ─── /learn + Stables Affiliate ────────────────────────────────────────────
# Affiliate URL for Stables onramp integration in /learn content section.
# Apply at stables.money — approval takes 48+ hours. Set once approved.
# NEXT_PUBLIC_STABLES_AFFILIATE_URL=https://stables.money/ref/your-affiliate-id
